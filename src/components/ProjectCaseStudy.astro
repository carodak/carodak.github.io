---
import ProgressNav from './ProgressNav.astro';
import { localizedPath, type Language } from '../data/site';

interface Props {
	language: Language;
	copy: any;
	project: any;
}

const { language, copy, project } = Astro.props;
const projects = copy.projects.items
	.map((item) => ({
		...item,
		categories: item.categories ?? (item.featuredPosition ? ['Featured'] : []),
	}))
	.sort((a, b) => (a.featuredPosition ?? 999) - (b.featuredPosition ?? 999));
const activeMenuFilter = project.categories?.includes('Featured') ? 'Featured' : (project.categories?.[0] ?? 'Featured');
const caseStudy = project.caseStudy ?? {};
const projectVisual = project.visual ?? {
	title: project.title,
	theme: 'dark',
	tags: [],
	media: [{ type: 'mockup', label: project.title }],
};
const categories = (project.categories?.length ? project.categories : [project.discipline]).filter(Boolean);
const visuals = projectVisual.media?.length ? projectVisual.media : [{ type: 'mockup', label: project.title }];
const overview = caseStudy.overview ?? [
	{ label: 'My Role', value: project.role },
	{ label: 'Timeline', value: project.timeline },
];
const hasText = (value) => typeof value === 'string' && value.trim().length > 0;
const caseLinks = (caseStudy.links ?? []).filter((link) => hasText(link?.href));
const getPoints = (item) => (Array.isArray(item?.points) ? item.points.filter(hasText) : []);
const problem = caseStudy.problem;
const solution = caseStudy.solution;
const processItems = Array.isArray(caseStudy.process)
	? caseStudy.process
	: hasText(caseStudy.process?.description)
		? [{ title: 'Process', body: caseStudy.process.description }]
		: [];
const challenges = caseStudy.challenges ?? [];
const impacts =
	caseStudy.impact ??
	caseStudy.results?.map((result) => ({
		title: result.value,
		description: result.label,
	})) ??
	[];
const hasProblem = problem && hasText(problem.title) && hasText(problem.description);
const hasSolution = solution && hasText(solution.title) && hasText(solution.description);
const hasTldr = hasProblem || hasSolution;
const hasProcesses = processItems.some((item) => hasText(item.title) || hasText(item.body));
const getChallengeDetails = (challenge) => [
	challenge.description,
	...(challenge.solutions ?? []),
].filter(hasText);
const hasChallenges = challenges.some((item) => hasText(item.title) || getChallengeDetails(item).length);
const hasImpacts = impacts.some((item) => hasText(item.title) || hasText(item.description));
const getYouTubeEmbedUrl = (src = '') => {
	const match = src.match(/(?:youtube\.com\/watch\?v=|youtu\.be\/)([^&?/]+)/);
	const id = match?.[1];
	return id ? `https://www.youtube.com/embed/${id}?rel=0&playsinline=1` : '';
};
---

<ProgressNav language={language} isHome={false} />

<aside class="case-side-nav" aria-label="Project navigation">
	<p>Projects</p>
	<div class="case-side-filters">
		{copy.projects.filters.map((filter) => (
			<button
				type="button"
				class:list={[filter === activeMenuFilter && 'active']}
				data-case-project-filter={filter}
			>
				{filter}
			</button>
		))}
	</div>
	{
		copy.projects.filters.map((filter) => (
			<div class:list={['case-side-projects', filter !== activeMenuFilter && 'is-hidden']} data-case-project-group={filter}>
				{projects
					.filter((item) => item.categories.includes(filter))
					.map((item) => (
						<a
							class:list={[item.slug === project.slug && 'active']}
							href={localizedPath(language, `/projects/${item.slug}/`)}
						>
							{item.title}
						</a>
					))}
			</div>
		))
	}
</aside>

<main class="case-study-page">
	<a class="case-back" href={`${localizedPath(language, '/')}#projects`}>
		<span aria-hidden="true"></span>
		{copy.pages.project.back}
	</a>

	<section class="case-hero">
		<h1>{caseStudy.heroTitle ?? project.title}</h1>
		<ul class="case-categories" aria-label="Project categories">
			{categories.map((category) => <li>{category}</li>)}
		</ul>
	</section>

	<section class="case-visual-gallery" aria-label={`${project.title} visuals`}>
		<div class="case-visual-track" data-case-visual-track>
			{
				visuals.map((item, index) => (
					<figure class="case-visual-slide">
						<div class:list={['project-visual', `project-visual-${projectVisual.theme}`]}>
							{
								item?.src ? (
									item.type === 'video' && getYouTubeEmbedUrl(item.src) ? (
										<iframe
											class="project-preview-media project-preview-embed"
											src={getYouTubeEmbedUrl(item.src)}
											title={item.label}
											loading={index === 0 ? 'eager' : 'lazy'}
											allow="accelerometer; autoplay; clipboard-write; encrypted-media; gyroscope; picture-in-picture; web-share"
											allowfullscreen
										></iframe>
									) : item.type === 'video' ? (
										<video class="project-preview-media" src={item.src} autoplay muted loop playsinline />
									) : (
										<img class="project-preview-media" src={item.src} alt={item.label} loading={index === 0 ? 'eager' : 'lazy'} />
									)
								) : index === 0 ? (
									<div class="flexd-mark">
										{projectVisual.tags.map((tag, tagIndex) => (
											<span class={`pill pill-${tagIndex + 1}`}>{tag}</span>
										))}
										<strong>{projectVisual.title}</strong>
									</div>
								) : (
									<div class="flexd-mark case-visual-placeholder">
										<strong>{item.label}</strong>
									</div>
								)
							}
						</div>
						<figcaption>{item.label}</figcaption>
					</figure>
				))
			}
		</div>
		{
			visuals.length > 1 && (
				<button class="case-visual-button case-visual-prev" type="button" data-case-visual-prev aria-label="Previous visual">
					<span aria-hidden="true" />
				</button>
			)
		}
		<button class="case-visual-next" type="button" data-case-visual-next aria-label="Next visual">
			<span aria-hidden="true"></span>
		</button>
	</section>

	<section class="case-introduction">
		<p class="case-kicker">Introduction</p>
		<div class="case-info-grid">
			<div>
				<h2>What was this project about?</h2>
				<p set:html={caseStudy.heroSubtitle ?? project.description} />
			</div>
			{overview.filter((item) => item.label !== 'Category' && (hasText(item.label) || hasText(item.value))).map((item) => (
				<div>
					<h2>{item.label}</h2>
					<p set:html={item.value} />
				</div>
			))}
			{caseLinks.length > 0 && (
				<div>
					<h2>Links</h2>
					<p class="case-links">
						{caseLinks.map((link, index) => (
							<>
								<a href={link.href} target="_blank" rel="noreferrer" aria-label={link.label ?? `Project link ${index + 1}`}>
									{index + 1}
								</a>
								{index < caseLinks.length - 1 && <span aria-hidden="true">|</span>}
							</>
						))}
					</p>
				</div>
			)}
		</div>
	</section>

	{
		hasTldr && (
			<section class="case-tldr">
				<span class="case-tldr-badge">Quick<br />TL;DR</span>
				{hasProblem && (
					<div class="case-tldr-row">
						<p class="case-kicker">Problem</p>
						<h2>{problem.title}</h2>
						{
							getPoints(problem).length ? (
								<ul>
									{getPoints(problem).map((point) => <li>{point}</li>)}
								</ul>
							) : (
								<p>{problem.description}</p>
							)
						}
					</div>
				)}
				{hasSolution && (
					<div class="case-tldr-row">
						<p class="case-kicker">Solution</p>
						<h2>{solution.title}</h2>
						{
							getPoints(solution).length ? (
								<ul>
									{getPoints(solution).map((point) => <li>{point}</li>)}
								</ul>
							) : (
								<p>{solution.description}</p>
							)
						}
					</div>
				)}
			</section>
		)
	}

	{
		hasProcesses && (
			<section class="case-process">
				<span class="case-process-badge">More<br />information</span>
				<p class="case-kicker">Process</p>
				<div class="case-process-list">
					{processItems.filter((card) => hasText(card.title) || hasText(card.body)).map((card, index) => (
						<article>
							<span>{String(index + 1).padStart(2, '0')}</span>
							<p>{card.body}</p>
						</article>
					))}
				</div>
			</section>
		)
	}

	{
		hasChallenges && (
			<section class="case-challenges">
				<p class="case-kicker">Challenges Faced</p>
				<div class="case-challenge-grid">
					{challenges.filter((challenge) => hasText(challenge.title) || getChallengeDetails(challenge).length).map((challenge, index) => (
						<article>
							<span>{String(index + 1).padStart(2, '0')}</span>
							<h2>{challenge.title}</h2>
							{getChallengeDetails(challenge).length > 0 && (
								<ul>
									{getChallengeDetails(challenge).map((solutionItem) => <li>{solutionItem}</li>)}
								</ul>
							)}
						</article>
					))}
				</div>
			</section>
		)
	}

	{
		hasImpacts && (
			<section class="case-impact">
				<p class="case-kicker">Impact</p>
				<div class="case-impact-grid">
					{impacts.filter((item) => hasText(item.title) || hasText(item.description)).map((item) => (
						<article>
							<h2>{item.title}</h2>
							<p set:html={item.description} />
						</article>
					))}
				</div>
			</section>
		)
	}
</main>

<script>
	const visualTrack = document.querySelector('[data-case-visual-track]');
	const visualPrev = document.querySelector('[data-case-visual-prev]');
	const visualNext = document.querySelector('[data-case-visual-next]');
	const caseProjectFilters = Array.from(document.querySelectorAll('[data-case-project-filter]'));
	const caseProjectGroups = Array.from(document.querySelectorAll('[data-case-project-group]'));

	const scrollVisual = (direction) => {
		if (!visualTrack) return;

		const slide = visualTrack.querySelector('.case-visual-slide');
		const slideWidth = slide?.getBoundingClientRect().width || visualTrack.clientWidth;
		const scrollAmount = slideWidth + 24;
		const isAtEnd = visualTrack.scrollLeft + visualTrack.clientWidth >= visualTrack.scrollWidth - 4;
		const isAtStart = visualTrack.scrollLeft <= 4;

		visualTrack.scrollTo({
			left: direction > 0 && isAtEnd ? 0 : direction < 0 && isAtStart ? visualTrack.scrollWidth : visualTrack.scrollLeft + direction * scrollAmount,
			behavior: 'smooth',
		});
	};

	visualPrev?.addEventListener('click', () => scrollVisual(-1));
	visualNext?.addEventListener('click', () => scrollVisual(1));

	caseProjectFilters.forEach((button) => {
		button.addEventListener('click', () => {
			const filter = button.getAttribute('data-case-project-filter') || 'Featured';

			caseProjectFilters.forEach((item) => item.classList.toggle('active', item === button));
			caseProjectGroups.forEach((group) => {
				group.classList.toggle('is-hidden', group.getAttribute('data-case-project-group') !== filter);
			});
		});
	});
</script>
