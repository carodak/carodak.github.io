---
const dataSrc = '/projects/revenu-femmes-minorites-visibles/revenu-quebec-femmes.json';
---

<section class="income-explorer" data-income-explorer data-src={dataSrc} aria-labelledby="income-explorer-title">
	<div class="income-explorer-header">
		<p class="case-kicker">Visualisation interactive</p>
		<h2 id="income-explorer-title">Explorer les écarts de revenu par diplôme</h2>
		<p>
			Choisissez un groupe d’âge et quelques niveaux d’études. Commencez avec les revenus médians, puis examinez
			où les écarts observés sont les plus grands pour les femmes issues d’une minorité visible au Québec.
		</p>
	</div>

	<div class="income-controls" aria-label="Filtres de visualisation">
		<label>
			<span>Groupe d’âge</span>
			<select data-income-age></select>
		</label>
		<label>
			<span>Type de graphique</span>
			<select data-income-view>
				<option value="income">Revenus médians</option>
				<option value="landscape">Paysage des revenus</option>
				<option value="gap">Écart relatif</option>
				<option value="scatter">Plus grands écarts</option>
				<option value="donut">Répartition des écarts</option>
				<option value="sample">Effectifs</option>
			</select>
		</label>
	</div>

	<div class="income-summary" data-income-summary aria-live="polite"></div>

	<div class="income-layout">
		<div class="income-education-panel">
			<div class="income-panel-top">
				<p>Niveaux d’études</p>
				<div>
					<button type="button" data-income-select-all>Tout</button>
					<button type="button" data-income-select-key>Résumé</button>
				</div>
			</div>
			<div class="income-education-list" data-income-education-list></div>
		</div>

		<div class="income-chart-wrap">
			<svg class="income-chart" data-income-chart role="img" aria-labelledby="income-chart-title income-chart-desc">
				<title id="income-chart-title">Revenu d’emploi médian par niveau d’études</title>
				<desc id="income-chart-desc">Graphique interactif basé sur les filtres sélectionnés.</desc>
			</svg>
			<div class="income-tooltip" data-income-tooltip hidden></div>
		</div>
	</div>

	<div class="income-method">
		<p class="case-kicker">Source</p>
		<div>
			<p>
				Source: <a href="https://www150.statcan.gc.ca/t1/tbl1/fr/tv.action?pid=9810043901" target="_blank">tableau Statistique Canada 98-10-0439-01</a>,
				année de revenu 2020. L’analyse garde le Québec, les femmes (Women+), le revenu d’emploi médian et le statut
				d’immigration combiné "Non-immigrants and Immigrants."
			</p>
		</div>
	</div>
</section>

<script data-astro-rerun>
	(() => {
		window.__carodakIncomeExplorer?.abort();
		window.__carodakIncomeExplorer = new AbortController();
		const signal = window.__carodakIncomeExplorer.signal;
		const root = document.querySelector('[data-income-explorer]');
		if (!root) return;

		const ageSelect = root.querySelector('[data-income-age]');
		const viewSelect = root.querySelector('[data-income-view]');
		const summary = root.querySelector('[data-income-summary]');
		const educationList = root.querySelector('[data-income-education-list]');
		const chart = root.querySelector('[data-income-chart]');
		const tooltip = root.querySelector('[data-income-tooltip]');
		const selectAll = root.querySelector('[data-income-select-all]');
		const selectKey = root.querySelector('[data-income-select-key]');
		const dataSrc = root.getAttribute('data-src');
		const keyEducations = new Set([
			'High (secondary) school diploma or equivalency certificate',
			'College, CEGEP or other non-university certificate or diploma',
			"Bachelor's degree",
			"Master's degree",
			'Earned doctorate',
		]);
		let rows = [];
		let selected = new Set(keyEducations);

		const shortEducation = (label) => {
			const labels = {
				'No certificate, diploma or degree': 'Aucun diplôme',
				'High (secondary) school diploma or equivalency certificate': 'Secondaire',
				'Apprenticeship certificate': 'Apprentissage',
				'Non-apprenticeship trades certificate or diploma': 'Métiers, hors apprentissage',
				'Apprenticeship or trades certificate or diploma': 'Métiers',
				'College, CEGEP or other non-university certificate or diploma': 'Collège / Cégep',
				'University certificate or diploma below bachelor level': 'Certificat univ. sous le bac',
				'Postsecondary certificate or diploma below bachelor level': 'Postsecondaire sous le bac',
				"Bachelor's degree": 'Baccalauréat',
				'Bachelor’s degree or higher': 'Baccalauréat ou plus',
				'Bachelorâ€™s degree or higher': 'Baccalauréat ou plus',
				'University certificate or diploma above bachelor level': 'Certificat univ. au-dessus du bac',
				"Master's degree": 'Maîtrise',
				'Degree in medicine, dentistry, veterinary medicine or optometry': 'Médecine, dentisterie, médecine vétérinaire ou optométrie',
				'Earned doctorate': 'Doctorat',
				'Postsecondary certificate, diploma or degree': 'Postsecondaire',
			};
			return labels[label] ?? label;
		};

		const money = (value) =>
			new Intl.NumberFormat('fr-CA', { style: 'currency', currency: 'CAD', maximumFractionDigits: 0 }).format(value);
		const count = (value) => new Intl.NumberFormat('fr-CA', { maximumFractionDigits: 0 }).format(value ?? 0);
		const pct = (value) => `${value > 0 ? '+' : ''}${value.toFixed(1).replace('.', ',')} %`;
		const ageLabel = (age) => age.replaceAll('to', 'à').replaceAll('years', 'ans').replace('year', 'an');
		const countNote = (row) => {
			const minCount = Math.min(row.visible_minority_with_employment_income_count ?? Infinity, row.not_visible_minority_with_employment_income_count ?? Infinity);
			return minCount < 500 ? '<br><em>Petit groupe: interpréter avec prudence.</em>' : '';
		};
		const gapTooltip = (row) => `
			<strong>${shortEducation(row.education)}</strong><br>
			Femmes issues d’une minorité visible: ${money(row.visible_minority_income)}<br>
			Femmes non issues d’une minorité visible: ${money(row.not_visible_minority_income)}<br>
			Écart: ${money(row.gap_absolute)} (${pct(row.gap_relative_pct)})<br>
			Femmes incluses dans le revenu médian: ${count(row.visible_minority_with_employment_income_count)} contre ${count(row.not_visible_minority_with_employment_income_count)}
			${countNote(row)}
		`;

		const renderControls = () => {
			const ages = [...new Set(rows.map((row) => row.age_group))];
			ageSelect.innerHTML = ages.map((age) => `<option value="${age}">${ageLabel(age)}</option>`).join('');
			ageSelect.value = ages.includes('25 to 54 years') ? '25 to 54 years' : ages[0];

			const educations = [...new Set(rows.map((row) => row.education))];
			selectAll.textContent = selected.size === educations.length ? 'Effacer' : 'Tout';
			educationList.innerHTML = educations
				.map(
					(education) => `
						<label title="${education}">
							<input type="checkbox" value="${education}" ${selected.has(education) ? 'checked' : ''} />
							<span>${shortEducation(education)}</span>
						</label>
					`,
				)
				.join('');

			educationList.querySelectorAll('input').forEach((input) => {
				input.addEventListener(
					'change',
					() => {
						if (input.checked) selected.add(input.value);
						else selected.delete(input.value);
						render();
					},
					{ signal },
				);
			});
		};

			const svgEl = (name, attrs = {}) => {
				const el = document.createElementNS('http://www.w3.org/2000/svg', name);
				Object.entries(attrs).forEach(([key, value]) => el.setAttribute(key, value));
				return el;
			};

		const polarToCartesian = (centerX, centerY, radius, angleInDegrees) => {
			const angleInRadians = ((angleInDegrees - 90) * Math.PI) / 180;
			return {
				x: centerX + radius * Math.cos(angleInRadians),
				y: centerY + radius * Math.sin(angleInRadians),
			};
		};

		const describeArc = (centerX, centerY, outerRadius, innerRadius, startAngle, endAngle) => {
			const outerStart = polarToCartesian(centerX, centerY, outerRadius, endAngle);
			const outerEnd = polarToCartesian(centerX, centerY, outerRadius, startAngle);
			const innerStart = polarToCartesian(centerX, centerY, innerRadius, startAngle);
			const innerEnd = polarToCartesian(centerX, centerY, innerRadius, endAngle);
			const largeArcFlag = endAngle - startAngle <= 180 ? '0' : '1';

			return [
				`M ${outerStart.x} ${outerStart.y}`,
				`A ${outerRadius} ${outerRadius} 0 ${largeArcFlag} 0 ${outerEnd.x} ${outerEnd.y}`,
				`L ${innerStart.x} ${innerStart.y}`,
				`A ${innerRadius} ${innerRadius} 0 ${largeArcFlag} 1 ${innerEnd.x} ${innerEnd.y}`,
				'Z',
			].join(' ');
		};

		const pathFromPoints = (points) => points.map((point, index) => `${index === 0 ? 'M' : 'L'} ${point.x} ${point.y}`).join(' ');
		const areaFromPoints = (points, baselineY) =>
			`${pathFromPoints(points)} L ${points.at(-1).x} ${baselineY} L ${points[0].x} ${baselineY} Z`;

		const showTooltip = (event, html) => {
			tooltip.innerHTML = html;
			tooltip.hidden = false;
			const bounds = root.querySelector('.income-chart-wrap').getBoundingClientRect();
			tooltip.style.left = `${Math.min(event.clientX - bounds.left + 12, bounds.width - 220)}px`;
			tooltip.style.top = `${Math.max(event.clientY - bounds.top - 58, 8)}px`;
		};

		const hideTooltip = () => {
			tooltip.hidden = true;
		};

		const render = () => {
			const age = ageSelect.value;
			const view = viewSelect.value;
			let filtered = rows.filter((row) => row.age_group === age && selected.has(row.education));
			if (!filtered.length && selected.size > 0) {
				filtered = rows.filter((row) => row.age_group === age).slice(0, 5);
				selected = new Set(filtered.map((row) => row.education));
				renderControls();
			}
			if (!filtered.length) {
				summary.innerHTML = `
					<strong>0/0</strong>
					<span>Sélectionnez au moins un niveau d’études pour afficher le graphique.</span>
				`;
				chart.innerHTML = '';
				chart.setAttribute('viewBox', '0 0 960 260');
				const emptyTitle = svgEl('text', { x: 230, y: 130, class: 'income-chart-title' });
				emptyTitle.textContent = 'Aucun niveau d’études sélectionné';
				chart.append(emptyTitle);
				return;
			}

			const negativeCount = filtered.filter((row) => row.gap_relative_pct < 0).length;
			const strongest = [...filtered].sort((a, b) => a.gap_relative_pct - b.gap_relative_pct)[0];
			summary.innerHTML = `
				<strong>${negativeCount}/${filtered.length}</strong>
				<span>Dans cette sélection, ${negativeCount} niveau${negativeCount === 1 ? '' : 'x'} d’études affichent un revenu médian plus bas pour les femmes issues d’une minorité visible. Le plus grand écart relatif ici concerne <em>${shortEducation(strongest.education)}</em>.</span>
			`;

			chart.innerHTML = '';
			const width = 960;
			const wideViews = new Set(['scatter', 'donut', 'landscape']);
			const height = wideViews.has(view) ? 560 : Math.max(360, filtered.length * (view === 'income' ? 54 : 46) + 118);
			const margin = wideViews.has(view)
				? { top: 44, right: 42, bottom: 72, left: 92 }
				: { top: 34, right: 34, bottom: 54, left: 230 };
			chart.setAttribute('viewBox', `0 0 ${width} ${height}`);

			const plotWidth = width - margin.left - margin.right;
			const plotHeight = height - margin.top - margin.bottom;
			const groupGap = plotHeight / filtered.length;

			const title = svgEl('text', { x: margin.left, y: 20, class: 'income-chart-title' });
			title.textContent =
				view === 'gap'
					? 'Écart relatif par niveau d’études'
					: view === 'scatter'
						? 'Où sont les plus grands écarts?'
						: view === 'donut'
							? 'Répartition des écarts par niveau d’études'
							: view === 'landscape'
								? 'Paysage des revenus médians'
								: view === 'sample'
									? 'Femmes avec revenu d’emploi'
									: 'Revenu d’emploi médian par groupe';
			chart.append(title);

			if (view === 'gap') {
				const min = Math.min(-65, ...filtered.map((row) => row.gap_relative_pct));
				const max = Math.max(20, ...filtered.map((row) => row.gap_relative_pct));
				const zeroX = margin.left + ((0 - min) / (max - min)) * plotWidth;
				chart.append(svgEl('line', { x1: zeroX, x2: zeroX, y1: margin.top, y2: height - margin.bottom, class: 'income-zero-line' }));

				filtered.forEach((row, index) => {
					const y = margin.top + index * groupGap + groupGap * 0.24;
					const value = row.gap_relative_pct;
					const x = margin.left + ((Math.min(value, 0) - min) / (max - min)) * plotWidth;
					const barWidth = Math.abs(((value - 0) / (max - min)) * plotWidth);
					const bar = svgEl('rect', {
						x: value < 0 ? x : zeroX,
						y,
						width: Math.max(2, barWidth),
						height: Math.max(18, groupGap * 0.5),
						rx: 3,
						class: value < 0 ? 'income-bar-negative' : 'income-bar-positive',
					});
					bar.addEventListener('pointermove', (event) => showTooltip(event, gapTooltip(row)), { signal });
					bar.addEventListener('pointerleave', hideTooltip, { signal });
					chart.append(bar);

					const label = svgEl('text', { x: margin.left - 12, y: y + groupGap * 0.34, class: 'income-axis-label' });
					label.textContent = shortEducation(row.education);
					chart.append(label);
					const valueLabel = svgEl('text', {
						x: value < 0 ? x - 8 : zeroX + barWidth + 8,
						y: y + groupGap * 0.34,
						class: 'income-value-label',
					});
					valueLabel.textContent = pct(value);
					chart.append(valueLabel);
				});
			} else if (view === 'income') {
				const maxIncome = Math.max(...filtered.flatMap((row) => [row.visible_minority_income, row.not_visible_minority_income])) * 1.08;
				filtered.forEach((row, index) => {
					const y = margin.top + index * groupGap + groupGap * 0.14;
					const label = svgEl('text', { x: margin.left - 12, y: y + 24, class: 'income-axis-label' });
					label.textContent = shortEducation(row.education);
					chart.append(label);

					[
						['Femmes issues d’une minorité visible', row.visible_minority_income, 'income-bar-visible', 0],
						['Femmes non issues d’une minorité visible', row.not_visible_minority_income, 'income-bar-reference', 22],
					].forEach(([group, value, className, offset]) => {
						const bar = svgEl('rect', {
							x: margin.left,
							y: y + offset,
							width: Math.max(2, (Number(value) / maxIncome) * plotWidth),
							height: 16,
							rx: 3,
							class: className,
						});
						bar.addEventListener('pointermove', (event) => showTooltip(event, gapTooltip(row)), { signal });
						bar.addEventListener('pointerleave', hideTooltip, { signal });
						chart.append(bar);
					});
				});
			} else if (view === 'sample') {
				const maxCount = Math.max(...filtered.flatMap((row) => [row.visible_minority_with_employment_income_count ?? 0, row.not_visible_minority_with_employment_income_count ?? 0])) * 1.08;
				filtered.forEach((row, index) => {
					const y = margin.top + index * groupGap + groupGap * 0.14;
					const label = svgEl('text', { x: margin.left - 12, y: y + 24, class: 'income-axis-label' });
					label.textContent = shortEducation(row.education);
					chart.append(label);

					[
						['Femmes issues d’une minorité visible avec revenu d’emploi', row.visible_minority_with_employment_income_count, 'income-bar-visible', 0],
						['Femmes non issues d’une minorité visible avec revenu d’emploi', row.not_visible_minority_with_employment_income_count, 'income-bar-reference', 22],
					].forEach(([group, value, className, offset]) => {
						const numericValue = Number(value ?? 0);
						const bar = svgEl('rect', {
							x: margin.left,
							y: y + offset,
							width: Math.max(2, (numericValue / maxCount) * plotWidth),
							height: 16,
							rx: 3,
							class: className,
						});
						bar.addEventListener('pointermove', (event) => showTooltip(event, `<strong>${shortEducation(row.education)}</strong><br>${group}: ${count(numericValue)}<br>Écart de revenu médian: ${money(row.gap_absolute)} (${pct(row.gap_relative_pct)})${countNote(row)}`), { signal });
						bar.addEventListener('pointerleave', hideTooltip, { signal });
						chart.append(bar);

						const valueLabel = svgEl('text', {
							x: margin.left + (numericValue / maxCount) * plotWidth + 8,
							y: y + offset + 9,
							class: 'income-sample-label',
						});
						valueLabel.textContent = count(numericValue);
						chart.append(valueLabel);
					});
				});
			} else if (view === 'scatter') {
				const maxIncome = Math.max(...filtered.flatMap((row) => [row.visible_minority_income, row.not_visible_minority_income])) * 1.08;
				const minIncome = 0;
				const xFor = (value) => margin.left + ((value - minIncome) / (maxIncome - minIncome)) * plotWidth;
				const yFor = (value) => height - margin.bottom - ((value - minIncome) / (maxIncome - minIncome)) * plotHeight;
				const largest = [...filtered].sort((a, b) => Math.abs(b.gap_absolute) - Math.abs(a.gap_absolute)).slice(0, 4);
				const largestSet = new Set(largest.map((row) => row.education));

				for (let tick = 0; tick <= maxIncome; tick += 20000) {
					const x = xFor(tick);
					const y = yFor(tick);
					chart.append(svgEl('line', { x1: x, x2: x, y1: margin.top, y2: height - margin.bottom, class: 'income-grid-line' }));
					chart.append(svgEl('line', { x1: margin.left, x2: width - margin.right, y1: y, y2: y, class: 'income-grid-line' }));
				}
				chart.append(svgEl('line', { x1: margin.left, y1: height - margin.bottom, x2: width - margin.right, y2: margin.top, class: 'income-equality-line' }));
				const equalityNote = svgEl('text', { x: width - margin.right - 18, y: margin.top + 34, class: 'income-equality-label', 'text-anchor': 'end' });
				equalityNote.textContent = 'Ligne diagonale = revenu médian égal';
				chart.append(equalityNote);
				const belowNote = svgEl('text', { x: margin.left + 18, y: margin.top + 60, class: 'income-equality-label' });
				belowNote.textContent = 'Sous la ligne: revenu plus bas pour les femmes issues d’une minorité visible';
				chart.append(belowNote);

				filtered.forEach((row) => {
					const x = xFor(row.not_visible_minority_income);
					const y = yFor(row.visible_minority_income);
					const radius = Math.max(8, Math.min(34, Math.abs(row.gap_absolute) / 450));
					const point = svgEl('circle', {
						cx: x,
						cy: y,
						r: radius,
						class: row.gap_relative_pct < 0 ? 'income-dot-negative' : 'income-dot-positive',
					});
					point.addEventListener('pointermove', (event) => showTooltip(event, gapTooltip(row)), { signal });
					point.addEventListener('pointerleave', hideTooltip, { signal });
					chart.append(point);

					if (largestSet.has(row.education)) {
						const label = svgEl('text', { x: Math.min(x + radius + 8, width - margin.right - 180), y: y - radius - 4, class: 'income-bubble-label' });
						label.textContent = shortEducation(row.education);
						chart.append(label);
					}
				});

				const xLabel = svgEl('text', { x: margin.left + plotWidth / 2, y: height - 22, class: 'income-legend' });
				xLabel.textContent = 'Revenu médian: femmes non issues d’une minorité visible';
				chart.append(xLabel);
				const yLabel = svgEl('text', { x: 20, y: margin.top + plotHeight / 2, class: 'income-legend', transform: `rotate(-90 20 ${margin.top + plotHeight / 2})` });
				yLabel.textContent = 'Revenu médian: femmes issues d’une minorité visible';
				chart.append(yLabel);
			} else if (view === 'landscape') {
				const sorted = [...filtered].sort((a, b) => a.not_visible_minority_income - b.not_visible_minority_income);
				const maxIncome = Math.max(...sorted.flatMap((row) => [row.visible_minority_income, row.not_visible_minority_income])) * 1.08;
				const baselineY = height - margin.bottom;
				const xFor = (index) => margin.left + (index / Math.max(1, sorted.length - 1)) * plotWidth;
				const yFor = (value) => baselineY - (value / maxIncome) * plotHeight;
				const visiblePoints = sorted.map((row, index) => ({ x: xFor(index), y: yFor(row.visible_minority_income), row }));
				const referencePoints = sorted.map((row, index) => ({ x: xFor(index), y: yFor(row.not_visible_minority_income), row }));

				for (let tick = 0; tick <= maxIncome; tick += 20000) {
					const y = yFor(tick);
					chart.append(svgEl('line', { x1: margin.left, x2: width - margin.right, y1: y, y2: y, class: 'income-grid-line' }));
				}

				chart.append(svgEl('path', { d: areaFromPoints(referencePoints, baselineY), class: 'income-landscape-reference' }));
				chart.append(svgEl('path', { d: areaFromPoints(visiblePoints, baselineY), class: 'income-landscape-visible' }));
				chart.append(svgEl('path', { d: pathFromPoints(referencePoints), class: 'income-landscape-line-reference' }));
				chart.append(svgEl('path', { d: pathFromPoints(visiblePoints), class: 'income-landscape-line-visible' }));

				visiblePoints.forEach((point, index) => {
					const row = point.row;
					const target = svgEl('circle', {
						cx: point.x,
						cy: point.y,
						r: 7,
						class: row.gap_relative_pct < 0 ? 'income-dot-negative' : 'income-dot-positive',
					});
					target.addEventListener('pointermove', (event) => showTooltip(event, gapTooltip(row)), { signal });
					target.addEventListener('pointerleave', hideTooltip, { signal });
					chart.append(target);

					if (index === 0 || index === sorted.length - 1 || Math.abs(row.gap_absolute) === Math.max(...sorted.map((item) => Math.abs(item.gap_absolute)))) {
						const label = svgEl('text', { x: point.x, y: point.y - 14, class: 'income-bubble-label', 'text-anchor': index > sorted.length / 2 ? 'end' : 'start' });
						label.textContent = shortEducation(row.education);
						chart.append(label);
					}
				});

				const legendA = svgEl('text', { x: margin.left + 18, y: margin.top + 28, class: 'income-landscape-label-visible' });
				legendA.textContent = 'Femmes issues d’une minorité visible';
				chart.append(legendA);
				const legendB = svgEl('text', { x: margin.left + 18, y: margin.top + 54, class: 'income-landscape-label-reference' });
				legendB.textContent = 'Femmes non issues d’une minorité visible';
				chart.append(legendB);
			} else {
				const sorted = [...filtered].sort((a, b) => Math.abs(b.gap_absolute) - Math.abs(a.gap_absolute));
				const totalGap = sorted.reduce((sum, row) => sum + Math.abs(row.gap_absolute), 0) || 1;
				const centerX = 392;
				const centerY = 286;
				const outerRadius = 208;
				const innerRadius = 118;
				const colors = ['#6f54b8', '#8471bd', '#9a8ac8', '#b2a7d5', '#d2cce8', '#e2bc36', '#78a95f', '#4d9a8b', '#5576b8'];
				let angle = -90;

				sorted.forEach((row, index) => {
					const sliceAngle = (Math.abs(row.gap_absolute) / totalGap) * 360;
					const endAngle = angle + sliceAngle;
					const segment = svgEl('path', {
						d: describeArc(centerX, centerY, outerRadius, innerRadius, angle, endAngle),
						fill: colors[index % colors.length],
						class: row.gap_relative_pct < 0 ? 'income-donut-negative' : 'income-donut-positive',
					});
					segment.addEventListener('pointermove', (event) => showTooltip(event, gapTooltip(row)), { signal });
					segment.addEventListener('pointerleave', hideTooltip, { signal });
					chart.append(segment);

					if (index < 7) {
						const midAngle = angle + sliceAngle / 2;
						const labelPoint = polarToCartesian(centerX, centerY, outerRadius + 26, midAngle);
						const label = svgEl('text', {
							x: labelPoint.x,
							y: labelPoint.y,
							class: 'income-donut-label',
							'text-anchor': labelPoint.x < centerX ? 'end' : 'start',
						});
						label.textContent = shortEducation(row.education);
						chart.append(label);
					}

					angle = endAngle;
				});

				const centerTitle = svgEl('text', { x: centerX, y: centerY - 10, class: 'income-donut-center' });
				centerTitle.textContent = `${negativeCount}/${filtered.length}`;
				chart.append(centerTitle);
				const centerSubtitle = svgEl('text', { x: centerX, y: centerY + 22, class: 'income-donut-subtitle' });
				centerSubtitle.textContent = 'revenus plus bas';
				chart.append(centerSubtitle);

				const note = svgEl('text', { x: 690, y: 160, class: 'income-legend' });
				note.textContent = 'Taille du segment = écart absolu de revenu';
				chart.append(note);
				const note2 = svgEl('text', { x: 690, y: 186, class: 'income-legend' });
				note2.textContent = 'Survolez pour voir les deux groupes et l’écart';
				chart.append(note2);
			}

			const legend = svgEl('text', { x: margin.left, y: height - 18, class: 'income-legend' });
			legend.textContent =
				view === 'gap'
					? 'À gauche de zéro: revenu médian plus bas pour les femmes issues d’une minorité visible.'
					: view === 'scatter'
						? 'Chaque bulle est un niveau d’études. Les plus grosses bulles indiquent de plus grands écarts absolus; la diagonale marque des revenus égaux.'
					: view === 'donut'
							? 'Chaque segment de l’anneau est un niveau d’études. Les segments plus grands indiquent de plus grands écarts en dollars.'
							: view === 'landscape'
								? 'Les surfaces superposées tracent les deux groupes à travers les niveaux d’études sélectionnés, triés selon le revenu du groupe de référence.'
								: view === 'sample'
									? 'Les effectifs montrent combien de femmes sont derrière chaque comparaison.'
									: 'Violet: femmes issues d’une minorité visible. Noir: femmes non issues d’une minorité visible.';
			chart.append(legend);
		};

		fetch(dataSrc, { signal })
			.then((response) => response.json())
			.then((data) => {
				rows = data.map((row) => ({
					...row,
					visible_minority_income: Number(row.visible_minority_income),
					not_visible_minority_income: Number(row.not_visible_minority_income),
					gap_absolute: Number(row.gap_absolute),
					gap_relative_pct: Number(row.gap_relative_pct),
					visible_minority_total_population_count: Number(row.visible_minority_total_population_count),
					not_visible_minority_total_population_count: Number(row.not_visible_minority_total_population_count),
					visible_minority_with_employment_income_count: Number(row.visible_minority_with_employment_income_count),
					not_visible_minority_with_employment_income_count: Number(row.not_visible_minority_with_employment_income_count),
				}));
				renderControls();
				render();
			})
			.catch(() => {
				summary.textContent = 'La visualisation interactive ne peut pas être chargée pour le moment.';
			});

		ageSelect.addEventListener('change', render, { signal });
		viewSelect.addEventListener('change', render, { signal });
		selectAll.addEventListener(
			'click',
			() => {
				const educations = [...new Set(rows.map((row) => row.education))];
				selected = selected.size === educations.length ? new Set() : new Set(educations);
				renderControls();
				render();
			},
			{ signal },
		);
		selectKey.addEventListener(
			'click',
			() => {
				selected = new Set(keyEducations);
				renderControls();
				render();
			},
			{ signal },
		);
	})();
</script>
