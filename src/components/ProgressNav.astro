---
import { chapterNav, type Language, localizedPath } from '../data/site';

interface Props {
	language: Language;
}

const { language } = Astro.props;
---

<aside class="progress-nav" aria-label="Page chapters">
	<ol>
		{
			chapterNav.map((chapter) => (
				<li>
					<a
						href={chapter.kind === 'page' ? localizedPath(language, chapter.path) : `#${chapter.id}`}
						data-chapter-link={chapter.id}
						data-chapter-kind={chapter.kind}
					>
						<span class="chapter-dot" aria-hidden="true"></span>
						<span>{chapter.prefix}: {chapter.label}</span>
					</a>
				</li>
			))
		}
	</ol>
</aside>

<script>
	const links = Array.from(document.querySelectorAll('[data-chapter-link]'));
	const sections = links
		.filter((link) => link.getAttribute('data-chapter-kind') === 'section')
		.map((link) => document.getElementById(link.getAttribute('data-chapter-link') || ''))
		.filter(Boolean);

	const setActive = (id) => {
		links.forEach((link) => {
			const isSection = link.getAttribute('data-chapter-kind') === 'section';
			link.classList.toggle('active', isSection && link.getAttribute('data-chapter-link') === id);
		});
	};

	const observer = new IntersectionObserver(
		(entries) => {
			const visible = entries
				.filter((entry) => entry.isIntersecting)
				.sort((a, b) => b.intersectionRatio - a.intersectionRatio)[0];

			if (visible) setActive(visible.target.id);
		},
		{ rootMargin: '-35% 0px -45% 0px', threshold: [0.12, 0.35, 0.6] },
	);

	sections.forEach((section) => observer.observe(section));
</script>
