---
import { chapterNav, type Language, localizedPath } from '../data/site';

interface Props {
	language: Language;
	isHome?: boolean;
}

const { language, isHome = true } = Astro.props;

const sectionHref = (id: string) => {
	if (isHome) return `#${id}`;
	return `${localizedPath(language, '/')}#${id}`;
};

const chapterHref = (chapter) => chapter.kind === 'page' ? localizedPath(language, chapter.path) : sectionHref(chapter.id);
---

<aside class="progress-nav" aria-label="Page chapters" data-progress-nav-version="2">
	<button class="chapter-menu-toggle" type="button" aria-expanded="false" aria-label="Open chapter menu" data-chapter-menu-toggle>
		<span aria-hidden="true"></span>
	</button>
	<ol data-chapter-menu>
		<li class="chapter-home-item">
			<a class="chapter-home-link" href={localizedPath(language, '/')} aria-label="Home" title="Home">
				<img class="chapter-home-icon" src="/logo.png" alt="" aria-hidden="true" />
			</a>
		</li>
		{
			chapterNav.map((chapter) => (
				<li>
					<a
						href={chapterHref(chapter)}
						title={`${chapter.prefix}: ${chapter.label}`}
						aria-label={`${chapter.prefix}: ${chapter.label}`}
						data-chapter-link={chapter.id}
						data-chapter-kind={chapter.kind}
						data-chapter-path={chapter.kind === 'page' ? chapterHref(chapter) : ''}
					>
						<span class="chapter-dot" aria-hidden="true"></span>
						<span class="chapter-label">{chapter.prefix}: {chapter.label}</span>
					</a>
				</li>
			))
		}
	</ol>
</aside>

<script data-astro-rerun>
	(() => {
	window.__carodakProgressController?.abort();
	window.__carodakProgressController = new AbortController();
	const progressSignal = window.__carodakProgressController.signal;
	const progressNavVersion = '2';
	const currentScript = document.currentScript;
	const currentProgressNav = currentScript?.previousElementSibling?.matches?.('.progress-nav')
		? currentScript.previousElementSibling
		: Array.from(document.querySelectorAll('.progress-nav')).at(-1);

	const pruneProgressNavs = () => {
		Array.from(document.querySelectorAll('.progress-nav')).forEach((nav) => {
			const isCurrent = nav === currentProgressNav && nav.getAttribute('data-progress-nav-version') === progressNavVersion;
			nav.toggleAttribute('hidden', !isCurrent);
			nav.toggleAttribute('data-current-progress-nav', isCurrent);
			if (!isCurrent) nav.remove();
		});
	};

	pruneProgressNavs();

	if (!currentProgressNav) return;
	if (currentProgressNav.getAttribute('data-progress-nav-version') !== progressNavVersion) {
		currentProgressNav.remove();
		return;
	}

	const links = Array.from(currentProgressNav.querySelectorAll('[data-chapter-link]'));
	const chapterMenuToggle = currentProgressNav.querySelector('[data-chapter-menu-toggle]');
	let currentActiveId = null;
	const sections = links
		.filter((link) => link.getAttribute('data-chapter-kind') === 'section')
		.map((link) => document.getElementById(link.getAttribute('data-chapter-link') || ''))
		.filter(Boolean);

	const setActive = (id) => {
		const shouldScanActive = Boolean(id && id !== currentActiveId);

		links.forEach((link) => {
			const isActive = link.getAttribute('data-chapter-link') === id;
			link.classList.toggle('active', isActive);

			if (!isActive || shouldScanActive) {
				link.classList.remove('active-scan');
			}

			if (isActive && shouldScanActive) {
				void link.offsetWidth;
				link.classList.add('active-scan');
			}
		});

		currentActiveId = id || null;
	};

	const setChapterMenuOpen = (isOpen) => {
		currentProgressNav.classList.toggle('is-open', isOpen);
		chapterMenuToggle?.setAttribute('aria-expanded', String(isOpen));
		chapterMenuToggle?.setAttribute('aria-label', isOpen ? 'Close chapter menu' : 'Open chapter menu');
	};

	const normalizePath = (path) => {
		const normalized = path.replace(/\/+$/, '');
		return normalized || '/';
	};

	const getPageChapterId = () => {
		const currentPath = normalizePath(window.location.pathname);
		if (currentPath.includes('/projects/')) return 'projects';

		const currentPageLink = links.find((link) => {
			if (link.getAttribute('data-chapter-kind') !== 'page') return false;
			const href = link.getAttribute('href') || '';
			const linkPath = normalizePath(new URL(href, window.location.origin).pathname);
			return linkPath === currentPath;
		});

		return currentPageLink?.getAttribute('data-chapter-link') || null;
	};

	const updateActiveSection = () => {
		const pageChapterId = getPageChapterId();
		if (pageChapterId && !sections.length) {
			setActive(pageChapterId);
			return;
		}

		if (window.scrollY < 80) {
			setActive(pageChapterId);
			return;
		}

		const markerY = window.innerHeight * 0.38;
		const activeSection = sections.find((section) => {
			const rect = section.getBoundingClientRect();
			return rect.top <= markerY && rect.bottom >= markerY;
		});

		if (activeSection) {
			setActive(activeSection.id);
		} else {
			setActive(pageChapterId);
		}
	};

	chapterMenuToggle?.addEventListener('click', () => {
		setChapterMenuOpen(chapterMenuToggle.getAttribute('aria-expanded') !== 'true');
	}, { signal: progressSignal });

	links.forEach((link) => {
		link.addEventListener('click', () => setChapterMenuOpen(false), { signal: progressSignal });
	});

	document.addEventListener('click', (event) => {
		if (currentProgressNav.contains(event.target)) return;
		setChapterMenuOpen(false);
	}, { signal: progressSignal });

	document.addEventListener('keydown', (event) => {
		if (event.key === 'Escape') setChapterMenuOpen(false);
	}, { signal: progressSignal });
	document.addEventListener('astro:before-preparation', pruneProgressNavs, { signal: progressSignal });
	document.addEventListener('astro:before-swap', () => {
		setChapterMenuOpen(false);
		pruneProgressNavs();
	}, { signal: progressSignal });
	document.addEventListener('astro:after-swap', pruneProgressNavs, { signal: progressSignal });
	document.addEventListener('astro:page-load', pruneProgressNavs, { signal: progressSignal });

	const observer = new IntersectionObserver(
		(entries) => {
			const visible = entries
				.filter((entry) => entry.isIntersecting)
				.sort((a, b) => b.intersectionRatio - a.intersectionRatio)[0];

			if (visible) updateActiveSection();
		},
		{ rootMargin: '-35% 0px -45% 0px', threshold: [0.12, 0.35, 0.6] },
	);

	sections.forEach((section) => observer.observe(section));
	updateActiveSection();
	progressSignal.addEventListener('abort', () => observer.disconnect(), { once: true });
	window.addEventListener('scroll', updateActiveSection, { passive: true, signal: progressSignal });
	window.addEventListener('resize', updateActiveSection, { signal: progressSignal });
	})();
</script>
