---
import HeroModel from './HeroModel.astro';
import ProgressNav from './ProgressNav.astro';
import { getCopy, localizedPath, type Language } from '../data/site';

interface Props {
	language: Language;
}

const { language } = Astro.props;
const copy = getCopy(language);
const featuredProjects = copy.projects.items
	.filter((item) => item.featuredPosition)
	.sort((a, b) => a.featuredPosition - b.featuredPosition);
const project = featuredProjects[0];
const projectPreview = project.visual.media[0];
---

<ProgressNav language={language} />

<main class="home-page">
	<section class="hero-section">
		<HeroModel label={copy.hero.modelLabel} />
		<a class="scroll-cue" href="#intro" aria-label="Scroll to introduction">
			<span></span>
		</a>
	</section>

	<section class="intro-section" id="intro">
		<div class="intro-heading">
			<h1>{copy.intro.heading}</h1>
		</div>
		<div class="intro-side">
			<a class="scribble-link" href={localizedPath(language, '/about/')}>
				<span class="scribble-arrow" aria-hidden="true"></span>
				{copy.intro.callout}
			</a>
			<div class="intro-copy">
				<p set:html={copy.intro.body} />
				<a href={localizedPath(language, '/about/')}>{copy.intro.link}</a>
			</div>
		</div>
	</section>

	<section class="projects-section" id="projects" aria-labelledby="projects-heading">
		<div class="projects-heading-row">
			<p class="tiny-label project-label">{copy.projects.label}</p>
			<h2 id="projects-heading">{copy.projects.heading}</h2>
		</div>
		<a class="project-card" href={localizedPath(language, `/projects/${project.slug}/`)}>
			<div class="project-info">
				<p class="project-year">{project.year}</p>
				<h3>{project.title}</h3>
				<p>{project.description}</p>
				<dl>
					<div>
						<dt>Discipline</dt>
						<dd>{project.discipline}</dd>
					</div>
					<div>
						<dt>My Role</dt>
						<dd>{project.role}</dd>
					</div>
					<div>
						<dt>Timeline</dt>
						<dd>{project.timeline}</dd>
					</div>
				</dl>
				<span class="blue-button">{copy.projects.cardCta}</span>
			</div>
			<div class:list={['project-visual', `project-visual-${project.visual.theme}`]} aria-hidden="true">
				<div class="project-tabs">
					{featuredProjects.map((item) => <span>{String(item.featuredPosition).padStart(2, '0')}</span>)}
				</div>
				{
					projectPreview?.src ? (
						projectPreview.type === 'video' ? (
							<video class="project-preview-media" src={projectPreview.src} autoplay muted loop playsinline />
						) : (
							<img class="project-preview-media" src={projectPreview.src} alt="" loading="lazy" />
						)
					) : (
						<div class="flexd-mark">
							{project.visual.tags.map((tag, index) => (
								<span class={`pill pill-${index + 1}`}>{tag}</span>
							))}
							<strong>{project.visual.title}</strong>
						</div>
					)
				}
			</div>
		</a>
	</section>

	<section class="testimonial-section">
		<div>
			<h2>{copy.testimonial.heading}</h2>
			<div class="testimonial-quote">
				<span class="quote quote-left" aria-hidden="true">"</span>
				<p set:html={copy.testimonial.body} />
				<span class="quote quote-right" aria-hidden="true">"</span>
			</div>
		</div>
	</section>

	<section class="experience-section" id="resume" data-chapter>
		<div class="experience-heading-row">
			<p class="tiny-label">{copy.experience.eyebrow}</p>
			<h2>{copy.experience.heading}</h2>
		</div>
		<div class="experience-list">
			{
				copy.experience.items.map((item) => (
					<div class="experience-row">
						<h3>{item.place}</h3>
						<p>{item.role}</p>
						<time>{item.date}</time>
					</div>
				))
			}
		</div>
		<a class="blue-button resume-button" href="/resume.pdf" target="_blank" rel="noreferrer">{copy.experience.cta}</a>
	</section>

	<section class="contact-section" id="contact" data-chapter>
		<div class="contact-content">
			<a class="still-here" href={`mailto:${copy.contact.email}`}>{copy.contact.teaser}</a>
			<h2>{copy.contact.heading} <em>{copy.contact.headingEmphasis}</em></h2>
			<a class="email-link" href={`mailto:${copy.contact.email}`}>{copy.contact.email}</a>
		</div>
	</section>
</main>
