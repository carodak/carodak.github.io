---
import BaseLayout from '../../layouts/BaseLayout.astro';
import ProjectCaseStudy from '../../components/ProjectCaseStudy.astro';
import { getCopy } from '../../data/site';

export function getStaticPaths() {
	const copy = getCopy('en');
	return copy.projects.items.map((project) => ({ params: { slug: project.slug } }));
}

const language = 'en';
const copy = getCopy(language);
const project = copy.projects.items.find((item) => item.slug === Astro.params.slug);

if (!project) {
	throw new Error(`Project not found: ${Astro.params.slug}`);
}
---

<BaseLayout title={`${project.title} - ${copy.name}`} description={project.description} language={language} path={`/projects/${project.slug}/`}>
	<ProjectCaseStudy language={language} copy={copy} project={project} />
</BaseLayout>
